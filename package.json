{
  "name": "nourivex-runtime",
  "version": "1.2.1",
  "description": "Nourivex Engineering Runtime - Provider-agnostic AI engineering framework with 16 discipline skills and 5 specialized agents",
  "type": "module",
  "main": "opencode-plugin.mjs",
  "bin": {
    "nourivex": "cli/dist/index.js"
  },
  "exports": {
    ".": "./opencode-plugin.mjs"
  },
  "files": [
    "opencode-plugin.mjs",
    "skill.json",
    "skills/",
    "agents/",
    "adapters/",
