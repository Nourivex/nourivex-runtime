  "scripts": {
    "build:cli": "cd cli && npm run build",
    "dev:cli": "cd cli && npm run dev"
  },
  "keywords": [
    "opencode",
    "plugin",
    "mcp",
    "ai",
    "engineering",
    "tdd",
    "nourivex",
    "skills",
    "agents",
    "cli"
  ],
  "author": "Nourivex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nourivex/nourivex-runtime.git",
    "directory": "nourivex-runtime"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
