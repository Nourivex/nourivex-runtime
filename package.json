{
  "name": "nourivex-runtime",
  "version": "5.0.0",
  "description": "Nourivex Engineering Runtime - Provider-agnostic AI engineering framework with 17 discipline skills, 5 specialized agents, and persistent memory/goal/todo system",
  "type": "module",
  "main": "opencode-plugin.mjs",
  "bin": {
    "nourivex": "cli/dist/index.js",
    "nourivex-mcp": "mcp/dist/server.js"
  },
  "exports": {
    ".": "./opencode-plugin.mjs"
  },
  "files": [
    "opencode-plugin.mjs",
    "opencode.agents.json",
    "skill.json",
    "skills/",
    "agents/",
    "adapters/",
    ".opencode/",
    ".agents/",
    "mcp/dist/",
    "mcp/package.json",
    "cli/dist/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0"
  },
  "scripts": {
    "build:cli": "cd cli && npm run build",
    "dev:cli": "cd cli && npm run dev",
    "build:mcp": "cd mcp && npm run build",
    "dev:mcp": "cd mcp && npm run dev",
    "start:mcp": "cd mcp && npm start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "opencode",
    "plugin",
    "mcp",
    "ai",
    "engineering",
    "tdd",
    "nourivex",
    "skills",
    "agents",
    "cli"
  ],
  "author": "Nourivex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nourivex/nourivex-runtime.git",
    "directory": "nourivex-runtime"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
